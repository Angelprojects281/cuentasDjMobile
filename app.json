{
  "expo": {
    "name": "cuentasdjMobile",
    "slug": "cuentasdjMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logotipo.png",
    "userInterfaceStyle": "light",
    "scheme": "cuentasDJ",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logotipo.png",
        "backgroundImage": "./assets/logotipo.png",
        "monochromeImage": "./assets/logotipo.png"
      },
      "package": "com.angelprojects.cuentasdjMobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
